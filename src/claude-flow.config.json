{
  "version": "3.5",
  "agents": {
    "defaultType": "coder",
    "autoSpawn": false,
    "maxConcurrent": 8,
    "timeout": 300000,
    "providers": [
      {
        "name": "qwen",
        "enabled": true,
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "${DASHSCOPE_API_KEY}"
      },
      {
        "name": "google",
        "enabled": true,
        "apiKey": "${GEMINI_API_KEY}"
      },
      {
        "name": "openrouter",
        "enabled": true,
        "apiKey": "${OPENROUTER_API_KEY}"
      },
      {
        "name": "anthropic",
        "enabled": true
      }
    ]
  },
  "swarm": {
    "topology": "hierarchical",
    "maxAgents": 8,
    "autoScale": false,
    "coordinationStrategy": "leader",
    "healthCheckInterval": 30000
  },
  "memory": {
    "backend": "hybrid",
    "persistPath": "./data/memory",
    "cacheSize": 1000,
    "enableHNSW": true,
    "vectorDimension": 384
  },
  "mcp": {
    "serverHost": "localhost",
    "serverPort": 3000,
    "autoStart": false,
    "transportType": "stdio",
    "tools": []
  },
  "cli": {
    "colorOutput": true,
    "interactive": true,
    "verbosity": "normal",
    "outputFormat": "text",
    "progressStyle": "spinner"
  },
  "hooks": {
    "enabled": true,
    "autoExecute": true,
    "hooks": []
  },
  "queen-model": "anthropic/claude-opus-4-6",
  "routing-mode": "cost-optimized",
  "fallback-enabled": true,
  "smart-routing": true
}
