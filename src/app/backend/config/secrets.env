# LiquidChess Secrets
# DO NOT COMMIT THIS FILE TO VERSION CONTROL

# Discord Bot Token
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Application ID (from General Information tab)
DISCORD_APP_ID=your_discord_app_id_here

# Discord Public Key (for HTTP Interactions signature verification)
# Get from General Information tab in Discord Developer Portal
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Groq API Key for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# Google Drive Service Account (for meme distribution)
# Path to service account JSON file
GOOGLE_DRIVE_CREDENTIALS_PATH=config/google_service_account.json

# Google Drive Folder IDs for meme categories
GOOGLE_DRIVE_MEMES_FOLDER=your_memes_folder_id_here
GOOGLE_DRIVE_CHESS_FOLDER=your_chess_folder_id_here
GOOGLE_DRIVE_BLUNDERS_FOLDER=your_blunders_folder_id_here

# Redis credentials (for Tournament Mode)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: Stockfish path override
STOCKFISH_PATH=
